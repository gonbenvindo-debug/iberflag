{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/produtos", "destination": "/produtos.html" },
    { "source": "/contacto", "destination": "/contacto.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/envios", "destination": "/envios.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/personalizar", "destination": "/personalizar.html" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ]
}

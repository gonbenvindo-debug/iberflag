      "destination": "/pages/devolucoes.html"
    },
    {
      "source": "/produto/:slug/personalizar",
      "destination": "/pages/personalizar.html?slug=:slug"
    },
    {
      "source": "/encomenda/:codigo",
      "destination": "/pages/encomenda.html?codigo=:codigo"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/admin(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/es/admin(.*)",

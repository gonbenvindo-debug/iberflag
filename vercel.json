{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" },
    { "source": "/index", "destination": "/pages/index.html" },
    { "source": "/index.html", "destination": "/pages/index.html" },
    { "source": "/admin", "destination": "/pages/admin.html" },
    { "source": "/admin.html", "destination": "/pages/admin.html" },
    { "source": "/checkout", "destination": "/pages/checkout.html" },
    { "source": "/checkout.html", "destination": "/pages/checkout.html" },
    { "source": "/contacto", "destination": "/pages/contacto.html" },
    { "source": "/contacto.html", "destination": "/pages/contacto.html" },
    { "source": "/encomenda", "destination": "/pages/encomenda.html" },
    { "source": "/encomenda.html", "destination": "/pages/encomenda.html" },
    { "source": "/encomendas", "destination": "/pages/encomendas.html" },
    { "source": "/encomendas.html", "destination": "/pages/encomendas.html" },
    { "source": "/envios", "destination": "/pages/envios.html" },
    { "source": "/envios.html", "destination": "/pages/envios.html" },
    { "source": "/faq", "destination": "/pages/faq.html" },
    { "source": "/faq.html", "destination": "/pages/faq.html" },
    { "source": "/personalizar", "destination": "/pages/personalizar.html" },
    { "source": "/personalizar.html", "destination": "/pages/personalizar.html" },
    { "source": "/produtos", "destination": "/pages/produtos.html" },
    { "source": "/produtos.html", "destination": "/pages/produtos.html" },
    { "source": "/sobre", "destination": "/pages/sobre.html" },
    { "source": "/sobre.html", "destination": "/pages/sobre.html" },
    { "source": "/termos", "destination": "/pages/termos.html" },
    { "source": "/termos.html", "destination": "/pages/termos.html" },
    { "source": "/privacidade", "destination": "/pages/privacidade.html" },
    { "source": "/privacidade.html", "destination": "/pages/privacidade.html" },
    { "source": "/devolucoes", "destination": "/pages/devolucoes.html" },
    { "source": "/devolucoes.html", "destination": "/pages/devolucoes.html" }
  ],
  "headers": [
    {
      "source": "/assets/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ]
}

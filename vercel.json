  "rewrites": [
    {
      "source": "/api/pixabay-image",
      "destination": "/api/pixabay-search?mode=image"
    },
    {
      "source": "/docs",
      "destination": "/404.html"
    },
    {
      "source": "/docs/:path*",
      "destination": "/404.html"
    },
    {
      "source": "/pages",
      "destination": "/404.html"
    },
    {
      "source": "/pages/:path*",
      "destination": "/404.html"
    },
    {
      "source": "/scripts",
      "destination": "/404.html"
    },
    {
      "source": "/scripts/:path*",
      "destination": "/404.html"
    },
    {
      "source": "/supabase",
      "destination": "/404.html"
    },
    {
      "source": "/supabase/:path*",
      "destination": "/404.html"
    },
    {
      "source": "/config",
      "destination": "/404.html"
    },
    {
      "source": "/config/:path*",
      "destination": "/404.html"
    },
    {
      "source": "/es",
      "destination": "/es/index.html"
    },
    {
      "source": "/es/:path*",
      "destination": "/es/:path*/index.html"
    },
    {
      "source": "/lib",
      "destination": "/404.html"
    },
    {
      "source": "/lib/:path*",
      "destination": "/404.html"
    },
    {
      "source": "/dump.sql",
      "destination": "/404.html"
    },
    {
      "source": "/mobile-properties-check.png",
      "destination": "/404.html"
    },
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/admin",
      "destination": "/pages/admin.html"
    },
    {
      "source": "/admin-template-editor",
      "destination": "/pages/admin-template-editor.html"
    },
    {
      "source": "/checkout",
      "destination": "/pages/checkout.html"
    },
    {
      "source": "/checkout/sucesso",

{
  "version": 2,
  "cleanUrls": false,
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/index",
      "has": [
        {
          "type": "host",
          "value": "((.*)\\.vercel\\.app|www\\.iberflag\\.com)"
        }
      ],
      "destination": "https://iberflag.com/",
      "permanent": true
    },
    {
      "source": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "((.*)\\.vercel\\.app|www\\.iberflag\\.com)"
        }
      ],
      "destination": "https://iberflag.com/",
      "permanent": true
    },
    {
      "source": "/produtos.html",
      "has": [
        {
          "type": "host",
          "value": "((.*)\\.vercel\\.app|www\\.iberflag\\.com)"
        },
        {
          "type": "query",
          "key": "categoria",
          "value": "(?<categoria>.*)"
        }
      ],
      "destination": "https://iberflag.com/produtos/:categoria",
      "permanent": true
    },
    {
      "source": "/encomenda.html",
      "has": [
        {
          "type": "host",
          "value": "((.*)\\.vercel\\.app|www\\.iberflag\\.com)"
        },
        {
          "type": "query",
          "key": "codigo",
          "value": "(?<codigo>.*)"
        }
      ],
      "destination": "https://iberflag.com/encomenda/:codigo",
      "permanent": true
    },
    {
      "source": "/checkout-sucesso.html",
      "has": [
        {
          "type": "host",
          "value": "((.*)\\.vercel\\.app|www\\.iberflag\\.com)"
